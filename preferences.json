[
    {
        "property": "uc.theme.comptitle-enable-pinned.enabled",
        "label": "Enable titles in pinned and essential tabs",
        "type": "checkbox",
        "disabledOn": []
    },
    {
        "property": "uc.theme.comptitle-default-text.enabled",
        "label": "Disable deemphasized tab titles",
        "type": "checkbox",
        "disabledOn": []
    },
    {
        "property": "uc.theme.hide-toolbar-collapsed-sidebar.enabled",
        "label": "Auto-hide toolbar in collapsed sidebar mode",
        "type": "checkbox",
        "defaultValue": false,
        "disabledOn": []
    },
    {
        "property": "uc.theme.toolbar-float.modifier-key",
        "label": "Toolbar floating modifier key:",
        "type": "dropdown",
        "defaultValue": "Alt",
        "placeholder": false,
        "options": [
            {
                "label": "Alt / Option",
                "value": "Alt"
            },
            {
                "label": "Ctrl",
                "value": "Control"
            },
            {
                "label": "Shift",
                "value": "Shift"
            },
            {
                "label": "Command / Meta",
                "value": "Meta"
            }
        ],
        "disabledOn": []
    },
    {
        "type": "text",
        "label": "Note: the modifier key requires this mod's JS script. If installing directly from GitHub in Sine, enable sine.allow-unsafe-js or install from the Sine store."
    },
    {
        "property": "uc.theme.hide-tab-close-button.enabled",
        "label": "Hide tab close button",
        "type": "checkbox",
        "defaultValue": true,
        "disabledOn": []
    },
    {
        "property": "uc.theme.tab-close-button.size",
        "label": "Tab Close Button Size:",
        "type": "string",
        "defaultValue": "16px",
        "placeholder": "16px"
    },
    {
        "property": "uc.theme.tab-close-button.position",
        "label": "Tab Close Button Position:",
        "type": "dropdown",
        "processAs": "var",
        "defaultValue": "0 auto auto 0",
        "placeholder": false,
        "options": [
            {
                "label": "Top left",
                "value": "0 auto auto 0"
            },
            {
                "label": "Top right",
                "value": "0 0 auto auto"
            },
            {
                "label": "Bottom left",
                "value": "auto auto 0 0"
            },
            {
                "label": "Bottom right",
                "value": "auto 0 0 auto"
            }
        ],
        "disabledOn": []
    },
    {
        "property": "uc.theme.comptitle.width",
        "label": "Tab Title Width:",
        "type": "string",
        "defaultValue": "3ch",
        "placeholder": "3ch"
    },
    {
        "property": "uc.theme.comptitle.height",
        "label": "Tab Title Height:",
        "type": "string",
        "defaultValue": "1.2rem",
        "placeholder": "1.2rem"
    },
    {
        "property": "uc.theme.comptitle.font-size",
        "label": "Tab Title Font Size:",
        "type": "string",
        "defaultValue": "0.85rem",
        "placeholder": "0.85rem"
    },
    {
        "property": "uc.theme.comptitle.font-family",
        "label": "Tab Title Font Family:",
        "type": "string",
        "defaultValue": "inherit",
        "placeholder": "monospace"
    },
    {
        "property": "uc.theme.comptitle.border-radius",
        "label": "Tab Title Border Radius:",
        "type": "string",
        "defaultValue": "0px",
        "placeholder": "5px"
    },
    {
        "property": "uc.theme.comptitle-position-bottom.enabled",
        "label": "Show tab title at bottom",
        "type": "checkbox",
        "defaultValue": true,
        "disabledOn": []
    },
    {
        "property": "uc.theme.tab_indicator.color",
        "label": "Tab Indicator Color:",
        "type": "string",
        "defaultValue": "var(--tab-indicator-color)",
        "placeholder": "#0000ff"
    },
    {
        "property": "uc.theme.tab_indicator.gradient",
        "label": "Tab Indicator Gradient (if theme uses gradients):",
        "type": "string",
        "defaultValue": "var(--tab-indicator-gradient)",
        "placeholder": "linear-gradient(#444444, #dddddd)"
    },
    {
        "property": "uc.theme.tab_indicator.width",
        "label": "Tab Indicator Width:",
        "type": "string",
        "defaultValue": "4px",
        "placeholder": "4px"
    }
